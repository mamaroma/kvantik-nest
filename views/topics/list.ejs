<!DOCTYPE html>
<html lang="ru" id="top">
<head>
  <%- include('../partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('../partials/header', { activePage, session }) %>


  <main class="section-pad">
    <div class="kv-actions">
      <h2>Темы</h2>
      <% if (session?.isAuthed && session.role === 'ADMIN') { %><a class="btn" href="/topics/add">+ Добавить</a><% } %>
    </div>

    <% if (!topics.length) { %>
      <p>Пока нет тем. Нажмите «Добавить».</p>
    <% } %>

    <div class="grid">
      <% topics.forEach((t) => { %>
        <div class="card">
          <h3><a href="/topics/<%= t.id %>"><%= t.title %></a></h3>
          <p class="muted"><%= t.slug %></p>
          <% if (t.description) { %>
            <p><%= t.description %></p>
          <% } %>
          <% if (session?.isAuthed && session.role === 'ADMIN') { %><div class="kv-actions">
            <a class="btn btn--ghost" href="/topics/<%= t.id %>/edit">Редактировать</a>
            <form method="POST" action="/topics/<%= t.id %>?_method=DELETE" onsubmit="return confirm('Удалить тему? Связанные статьи перестанут быть валидными.');">
              <button class="btn btn--danger" type="submit">Удалить</button>
            </form>
          </div><% } %>
        </div>
      <% }) %>
    </div>
  </main>

  <%- include('../partials/footer', { session }) %>
</body>
</html>
