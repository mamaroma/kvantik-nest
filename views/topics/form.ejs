<!DOCTYPE html>
<html lang="ru" id="top">
<head>
  <%- include('../partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('../partials/header', { activePage, session }) %>

  <% const isEdit = mode === 'edit'; %>
  <% const actionUrl = isEdit
    ? (`/topics/${topic.id}?_method=PATCH`)
    : ('/topics');
  %>

  <main class="section-pad">
    <h2><%= isEdit ? 'Редактирование темы' : 'Новая тема' %></h2>

    <form class="kv-form" method="POST" action="<%= actionUrl %>">
      <label>
        Название
        <input name="title" required value="<%= topic?.title || '' %>" />
      </label>

      <label>
        Slug (опционально)
        <input name="slug" value="<%= topic?.slug || '' %>" />
      </label>

      <label>
        Описание
        <textarea name="description" rows="4"><%= topic?.description || '' %></textarea>
      </label>

      <div class="kv-actions">
        <button class="btn" type="submit"><%= isEdit ? 'Сохранить' : 'Создать' %></button>
        <a class="btn btn--ghost" href="/topics">Отмена</a>
      </div>
    </form>
  </main>

  <%- include('../partials/footer', { session }) %>
</body>
</html>
