<!DOCTYPE html>
<html lang="ru" id="top">
<head>
  <%- include('../partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('../partials/header', { activePage, session }) %>

  <main class="section-pad">
    <% if (!topic) { %>
      <h2>Тема не найдена</h2>
      <a class="btn" href="/topics">К списку</a>
    <% } else { %>
      <div class="kv-actions">
        <h2><%= topic.title %></h2>
        <% if (session?.isAuthed && session.role === 'ADMIN') { %>
          <div class="kv-actions">
            <a class="btn btn--ghost" href="/topics/<%= topic.id %>/edit">Редактировать</a>
            <form method="POST" action="/topics/<%= topic.id %>?_method=DELETE" onsubmit="return confirm('Удалить тему?');">
              <button class="btn btn--danger" type="submit">Удалить</button>
            </form>
          </div>
        <% } %>
      </div>

      <p class="muted">slug: <code><%= topic.slug %></code></p>
      <% if (topic.description) { %>
        <p><%= topic.description %></p>
      <% } %>

      <div class="kv-actions">
        <a class="btn" href="/topics">К списку</a>
      </div>
    <% } %>
  </main>

  <%- include('../partials/footer', { session }) %>
</body>
</html>
