<!DOCTYPE html>
<html lang="ru" id="top">
<head>
  <%- include('../partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('../partials/header', { activePage, session }) %>

  <% const suffix = session?.isAuthed ? ('?auth=1&user=' + encodeURIComponent(session.user)) : ''; %>

  <main class="section-pad">
    <div class="kv-actions">
      <h2>Пользователи</h2>
      <a class="btn" href="/users/add<%= suffix %>">+ Добавить</a>
    </div>

    <% if (!users.length) { %>
      <p>Пока нет пользователей. Нажмите «Добавить».</p>
    <% } %>

    <div class="grid">
      <% users.forEach((u) => { %>
        <div class="card">
          <h3><a href="/users/<%= u.id %><%= suffix %>"><%= u.name %></a></h3>
          <p class="muted"><%= u.email %> • <%= u.role %></p>
          <div class="kv-actions">
            <a class="btn btn--ghost" href="/users/<%= u.id %>/edit<%= suffix %>">Редактировать</a>
            <form method="POST" action="/users/<%= u.id %>?_method=DELETE<%= suffix ? '&' + suffix.slice(1) : '' %>" onsubmit="return confirm('Удалить пользователя?');">
              <button class="btn btn--danger" type="submit">Удалить</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </main>

  <%- include('../partials/footer', { session }) %>
</body>
</html>
