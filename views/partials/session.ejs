<%
  const pageToPath = {
    index: '/mvc',
    articles: '/articles',
    topics: '/topics',
    gallery: '/gallery',
    news: '/news',
    table: '/table',
    snippet: '/code',
    builder: '/builder',
    about: '/about',
    contacts: '/contacts',
    users: '/users',
    login: '/auth/login',
    register: '/auth/register',
  };
  const currentPath = pageToPath[activePage] || '/mvc';
%>
<div class="session-info">
  <% if (session?.isAuthed) { %>
    <span>Вы вошли как <strong><%= session.user %></strong> (<%= session.role %>)</span>
    <form method="POST" action="/auth/logout?returnTo=<%= encodeURIComponent(currentPath) %>" style="display:inline">
      <button class="btn-link" type="submit">Выйти</button>
    </form>
  <% } else { %>
    <a class="btn-link" href="/auth/login?returnTo=<%= encodeURIComponent(currentPath) %>">Войти</a>
    <a class="btn-link" href="/auth/register?returnTo=<%= encodeURIComponent(currentPath) %>">Регистрация</a>
  <% } %>
</div>
