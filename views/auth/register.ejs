<!DOCTYPE html>
<html lang="ru">
<head>
  <%- include('../partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('../partials/header', { activePage, session }) %>
  <main class="section-pad">
    <h2>Регистрация</h2>
    <% if (error) { %><p class="error"><%= error %></p><% } %>
    <form class="kv-form" method="POST" action="/auth/register?returnTo=<%= encodeURIComponent(returnTo) %>">
      <label>Имя<input name="name" required /></label>
      <label>Email<input type="email" name="email" required /></label>
      <label>Пароль<input type="password" name="password" required minlength="6" /></label>
      <div class="kv-actions">
        <button class="btn" type="submit">Зарегистрироваться</button>
        <a class="btn btn--ghost" href="/auth/login?returnTo=<%= encodeURIComponent(returnTo) %>">У меня уже есть аккаунт</a>
      </div>
    </form>
  </main>
  <%- include('../partials/footer', { session }) %>
</body>
</html>